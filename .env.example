PORT=3000
NODE_ENV=production

# Comma-separated allowed frontend origins for CORS and Socket.IO.
# Example:
# CLIENT_URL=https://your-app.vercel.app,https://your-app-git-main-yourname.vercel.app
CLIENT_URL=https://your-app.vercel.app

MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<dbName>
JWT_SECRET=replace-with-a-strong-secret

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=Chat App

ARCJET_API_KEY=ajkey_xxxxxxxxxxxxx
